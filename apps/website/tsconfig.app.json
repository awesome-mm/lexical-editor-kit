{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "allowJs": true,
    "resolveJsonModule": true,
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "lexical-editor-kit": ["../../packages/editor/src/index.ts"],
      "lexical-editor-kit/plugins": ["../../packages/editor/src/plugins.ts"],
      "lexical-editor-kit/nodes": ["../../packages/editor/src/nodes.ts"],
      "lexical-editor-kit/providers": ["../../packages/editor/src/providers.ts"],
      "lexical-editor-kit/playground": ["../../packages/editor/src/playground.ts"]
    }
  },
  "include": ["src"]
}
